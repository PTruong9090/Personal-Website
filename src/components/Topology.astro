---
/**
 * Clickable homelab topology (brief sections 6 and 9). Node inventory
 * verified against live docker ps / configs on 2026-07-18. Discretion
 * rules apply: media stack collapsed to one Jellyfin node, no IPs.
 * Desktop: interactive SVG. Small screens: structured list fallback.
 */
interface Node {
  id: string;
  x: number;
  y: number;
  w: number;
  h: number;
  label: string;
  sub?: string;
  href?: string;
  dashed?: boolean;
  muted?: boolean;
}

const nodes: Node[] = [
  // ingress
  { id: 'cf', x: 230, y: 36, w: 180, h: 34, label: 'Cloudflare Tunnels' },
  { id: 'ingress', x: 230, y: 150, w: 180, h: 34, label: 'cloudflared ×3 · Caddy' },
  // media-server services
  { id: 'planbear', x: 60, y: 210, w: 160, h: 40, label: 'PlanBear backend', sub: 'planbear.io', href: '/projects/planbear' },
  { id: 'tranad', x: 240, y: 210, w: 160, h: 40, label: 'TranAD + exporter', sub: 'anomaly scoring', href: '/projects/anomaly' },
  { id: 'prom', x: 420, y: 210, w: 160, h: 40, label: 'Prometheus · Grafana', sub: 'monitoring', href: '/homelab' },
  { id: 'visionx', x: 60, y: 270, w: 160, h: 40, label: 'VisionX', sub: 'in development', href: '/projects/visionx', dashed: true },
  { id: 'nextcloud', x: 240, y: 270, w: 160, h: 40, label: 'Nextcloud', muted: true },
  { id: 'jellyfin', x: 420, y: 270, w: 160, h: 40, label: 'Jellyfin media stack', muted: true },
  { id: 'homepage', x: 240, y: 330, w: 160, h: 36, label: 'Homepage dashboard', muted: true },
  // NAS
  { id: 'nfs', x: 60, y: 506, w: 200, h: 40, label: 'NFS exports', sub: 'media · nextcloud · backups', href: '/homelab' },
  { id: 'nasexp', x: 420, y: 506, w: 160, h: 40, label: 'node-exporter', sub: 'telemetry', href: '/homelab' },
  // external
  { id: 'supabase', x: 676, y: 196, w: 150, h: 40, label: 'Supabase', sub: 'PlanBear PostgreSQL' },
  { id: 'tailscale', x: 664, y: 430, w: 150, h: 36, label: 'Tailscale', sub: 'private mesh', dashed: true, muted: true },
];

interface Edge {
  d: string;
  labels?: { x: number; y: number; text: string; anchor?: 'start' | 'middle' }[];
}

const edges: Edge[] = [
  // internet -> cloudflared/caddy ingress
  { d: 'M 320 70 V 146' },
  // TranAD scores exported into Prometheus
  { d: 'M 400 230 H 416' },
  // PlanBear backend -> Supabase Postgres (routed above row A)
  {
    d: 'M 140 210 V 198 H 650 V 216 H 672',
    labels: [{ x: 560, y: 192, text: 'PostgreSQL', anchor: 'middle' }],
  },
  // nightly backup cron -> NAS NFS share (verified 2026-07-18)
  {
    d: 'M 140 420 V 502',
    labels: [
      { x: 150, y: 448, text: '03:00 cron', anchor: 'start' },
      { x: 150, y: 462, text: 'pg_dump → NFS', anchor: 'start' },
    ],
  },
  // Prometheus scrapes the NAS node-exporter over Tailscale
  {
    d: 'M 500 250 V 266 H 612 V 526 H 586',
    labels: [
      { x: 622, y: 366, text: 'node metrics', anchor: 'start' },
      { x: 622, y: 380, text: 'via Tailscale', anchor: 'start' },
    ],
  },
];

const containers = [
  { x: 40, y: 110, w: 560, h: 310, title: 'media-server', sub: '· ThinkCentre mini PC · Docker', ty: 136 },
  { x: 40, y: 470, w: 560, h: 100, title: 'unraid-nas', sub: '· 18 TB parity array', ty: 494 },
];

const cx = (n: Node) => n.x + n.w / 2;
const labelY = (n: Node) => (n.sub ? n.y + n.h / 2 - 3 : n.y + n.h / 2 + 4);
---

<figure>
  <svg
    viewBox="0 0 860 584"
    class="topology hidden w-full md:block"
    aria-labelledby="topology-title"
    role="group"
  >
    <title id="topology-title">
      Homelab topology: Cloudflare Tunnels route into a mini PC running
      PlanBear, anomaly detection, monitoring, and personal services, backed
      by an Unraid NAS. Linked nodes open their case studies.
    </title>
    <defs>
      <marker
        id="arrow"
        viewBox="0 0 8 8"
        refX="7"
        refY="4"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 8 4 L 0 8 z" class="arrowhead"></path>
      </marker>
    </defs>

    <text x="320" y="24" text-anchor="middle" class="zone-label">INTERNET</text>

    {
      containers.map((c) => (
        <g>
          <rect x={c.x} y={c.y} width={c.w} height={c.h} rx="10" class="container-box" />
          <text x={c.x + 18} y={c.ty} class="container-title">
            {c.title}
            <tspan class="container-sub"> {c.sub}</tspan>
          </text>
        </g>
      ))
    }

    {
      edges.map((e) => (
        <g>
          <path d={e.d} class="edge" marker-end="url(#arrow)" />
          {e.labels?.map((l) => (
            <text x={l.x} y={l.y} text-anchor={l.anchor ?? 'middle'} class="edge-label">
              {l.text}
            </text>
          ))}
        </g>
      ))
    }

    {
      nodes.map((n) => {
        const box = (
          <>
            <rect
              x={n.x}
              y={n.y}
              width={n.w}
              height={n.h}
              rx="6"
              class:list={['node-box', { dashed: n.dashed, muted: n.muted }]}
            />
            <text x={cx(n)} y={labelY(n)} text-anchor="middle" class:list={['node-label', { muted: n.muted }]}>
              {n.label}
            </text>
            {n.sub && (
              <text x={cx(n)} y={n.y + n.h / 2 + 12} text-anchor="middle" class="node-sub">
                {n.sub}
              </text>
            )}
          </>
        );
        return n.href ? (
          <a href={n.href} aria-label={`${n.label} - open case study`}>
            {box}
          </a>
        ) : (
          <g>{box}</g>
        );
      })
    }
  </svg>

  <!-- Small-screen fallback: same information, structured list -->
  <div class="space-y-5 md:hidden">
    <p class="zone-label-html">INTERNET → Cloudflare Tunnels → cloudflared ×3 · Caddy</p>

    <div class="overflow-hidden rounded-xl border border-border bg-surface">
      <p class="border-b border-border px-5 py-4 font-mono text-sm">
        media-server
        <span class="text-muted"> · ThinkCentre mini PC · Docker</span>
      </p>
      <ul class="divide-y divide-border/60">
        <li class="px-5 py-3.5">
          <a class="text-accent underline underline-offset-4" href="/projects/planbear">PlanBear backend</a>
          <span class="text-sm text-muted"> · planbear.io</span>
        </li>
        <li class="px-5 py-3.5">
          <a class="text-accent underline underline-offset-4" href="/projects/anomaly">TranAD + exporter</a>
          <span class="text-sm text-muted"> · anomaly scoring</span>
        </li>
        <li class="px-5 py-3.5">
          <a class="text-accent underline underline-offset-4" href="/homelab">Prometheus · Grafana</a>
          <span class="text-sm text-muted"> · monitoring</span>
        </li>
        <li class="px-5 py-3.5">
          <a class="text-accent underline underline-offset-4" href="/projects/visionx">VisionX</a>
          <span class="text-sm text-muted"> · in development</span>
        </li>
        <li class="px-5 py-3.5 text-sm leading-relaxed text-muted">
          Nextcloud · Jellyfin media stack · Homepage dashboard
        </li>
      </ul>
    </div>

    <div class="overflow-hidden rounded-xl border border-border bg-surface">
      <p class="border-b border-border px-5 py-4 font-mono text-sm">
        unraid-nas
        <span class="text-muted"> · 18 TB parity array</span>
      </p>
      <ul class="divide-y divide-border/60">
        <li class="px-5 py-3.5">
          <a class="text-accent underline underline-offset-4" href="/homelab">NFS exports</a>
          <span class="text-sm text-muted"> · media · nextcloud · backups</span>
        </li>
        <li class="px-5 py-3.5">
          <a class="text-accent underline underline-offset-4" href="/homelab">node-exporter</a>
          <span class="text-sm text-muted"> · telemetry</span>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-border bg-surface px-5 py-4">
      <p class="font-mono text-xs tracking-wide text-muted uppercase">Flows</p>
      <ul class="mt-3 space-y-2 font-mono text-xs leading-relaxed text-muted">
        <li>PlanBear backend → Supabase (PostgreSQL)</li>
        <li>03:00 cron · pg_dump → NFS → NAS</li>
        <li>Prometheus → NAS node metrics via Tailscale</li>
      </ul>
    </div>
  </div>
</figure>

<style>
  .topology {
    height: auto;
  }

  .zone-label,
  .edge-label,
  .container-title,
  .node-label,
  .node-sub {
    font-family: var(--font-mono);
  }

  .zone-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    fill: var(--color-muted);
  }

  .zone-label-html {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .container-box {
    fill: none;
    stroke: var(--color-border);
    stroke-width: 1.5;
  }

  .container-title {
    font-size: 13px;
    fill: var(--color-text);
  }

  .container-sub {
    font-size: 10px;
    fill: var(--color-muted);
  }

  .edge {
    fill: none;
    stroke: var(--color-muted);
    stroke-opacity: 0.55;
    stroke-width: 1.2;
  }

  .arrowhead {
    fill: var(--color-muted);
    fill-opacity: 0.7;
  }

  .edge-label {
    font-size: 9px;
    fill: var(--color-muted);
  }

  .node-box {
    fill: var(--color-surface);
    stroke: var(--color-border);
    stroke-width: 1;
  }

  .node-box.dashed {
    stroke-dasharray: 4 3;
  }

  .node-label {
    font-size: 12px;
    fill: var(--color-text);
  }

  .node-label.muted,
  .node-box.muted + .node-label {
    fill: var(--color-muted);
  }

  .node-sub {
    font-size: 9px;
    fill: var(--color-muted);
  }

  svg a {
    cursor: pointer;
  }

  svg a:hover .node-box,
  svg a:focus-visible .node-box {
    stroke: var(--color-accent);
    stroke-width: 1.5;
  }

  svg a:hover .node-label,
  svg a:focus-visible .node-label {
    fill: var(--color-accent);
  }

  svg a:focus {
    outline: none;
  }
</style>
