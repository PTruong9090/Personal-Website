---
/**
 * Metric with its caveat inline, never in a footnote (brief section 7).
 */
interface Props {
  value: string;
  label: string;
  caveat?: string;
}

const { value, label, caveat } = Astro.props;
---

<div class="rounded-lg border border-border bg-surface px-4 py-3">
  <div class="font-mono text-xl text-text">{value}</div>
  <div class="mt-1 text-xs text-muted">{label}</div>
  {caveat && <div class="mt-1 font-mono text-xs text-status-dev">{caveat}</div>}
</div>
